{
  "manifest_version": 3,
  "name": "书签WebDAV备份",
  "version": "1.0.0",
  "description": "将浏览器书签备份到WebDAV，支持加密存储和双向同步",
  "permissions": [
    "bookmarks",
    "storage",
    "activeTab",
    "contextMenus",
    "notifications",
    "favicon"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "chrome_url_overrides": {
    "newtab": "newtab/newtab.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["_favicon/*"],
      "matches": ["<all_urls>"],
      "use_dynamic_url": true
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "bookmark-webdav-backup@example.com",
      "strict_min_version": "109.0"
    }
  }
}

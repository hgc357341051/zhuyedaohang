{
  "manifest_version": 3,
  "name": "云启 · 新标签页",
  "version": "2.0.0",
  "description": "个性化新标签页：时钟、搜索、快捷链接、备忘笔记、书签，支持组件外观自定义与WebDAV云同步",
  "permissions": [
    "bookmarks",
    "storage",
    "activeTab",
    "contextMenus",
    "notifications",
    "favicon"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "chrome_url_overrides": {
    "newtab": "newtab/newtab.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["_favicon/*"],
      "matches": ["<all_urls>"],
      "use_dynamic_url": true
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "cloud-start-newtab@example.com",
      "strict_min_version": "109.0"
    }
  }
}
